---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {%- assign latest_post = site.posts | first -%}
  {%- if latest_post -%}
    {%- assign site_lastmod = latest_post.last_modified_at | default: latest_post.date | date: "%Y-%m-%d" -%}
  {%- else -%}
    {%- assign site_lastmod = site.time | date: "%Y-%m-%d" -%}
  {%- endif -%}
  <sitemap>
    <loc>{{ site.domainUrl }}{{ site.baseurl }}/static/xml/sitemap-posts.xml</loc>
    <lastmod>{{ site_lastmod }}</lastmod>
  </sitemap>
  <sitemap>
    <loc>{{ site.domainUrl }}{{ site.baseurl }}/static/xml/sitemap-pages.xml</loc>
    <lastmod>{{ site_lastmod }}</lastmod>
  </sitemap>
</sitemapindex>
