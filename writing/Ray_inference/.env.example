# 复制为 .env 后按需修改;.env 已被 .dockerignore 排除

# ===== 服务 =====
ONLINE_API_HOST=0.0.0.0
ONLINE_API_PORT=7890

# ===== Ray =====
# 容器内 dashboard 绑 0.0.0.0 才能从宿主机访问;留 127.0.0.1 等价于不对外
RAY_DASHBOARD_HOST=0.0.0.0
# 远程 Ray 集群:形如 ray://head-node:10001;留空 = 容器内本地集群
RAY_ADDRESS=

# ===== Milvus =====
# 默认走 Lite 单文件;切 standalone 改成 http://milvus:19530
MILVUS_URI=/app/data/milvus_lite.db
MILVUS_TOKEN=

# ===== 模型 revision 锁定(留空 = 跟主分支) =====
CLIP_REVISION=
ONEFORMER_REVISION=
QWEN_EMBED_REVISION=

# ===== 日志格式 =====
# text:人读单行;json:结构化单行(Loki / ES / Datadog 直接抓 stdout)
LOG_FORMAT=text

# ===== HuggingFace =====
# 国内加速可选
# HF_ENDPOINT=https://hf-mirror.com
# 已 prepare 完后可设为 1 强制离线,完全跳 hub HEAD 验证
# HF_HUB_OFFLINE=1
